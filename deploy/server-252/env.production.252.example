# 192.168.9.252 production template (no secrets) — merge into repo root `.env`
#   scp deploy/server-252/clean-env-252.py admin@192.168.9.252:~/claw-code/deploy/server-252/
#   python3 deploy/server-252/clean-env-252.py ~/claw-code/.env
#   ./deploy/stack/gateway.sh up --release release-v1.4.6
# Author: kejiqing

CLAW_DEPLOY_PROFILE=production
CLAW_CLUSTER_ID=prod-claw-252

# LLM bootstrap until Admin → PG sync (do not commit real keys)
# UPSTREAM_OPENAI_BASE_URL=https://your-llm-gw/v1
# OPENAI_API_KEY=
# CLAW_DEFAULT_MODEL=openai/qwen3-max

CLAW_IMAGE_REGISTRY=acr

GATEWAY_HOST_PORT=18088
CLAW_TIMEOUT_SECONDS=1800

CLAW_CONTAINER_RUNTIME=docker
CLAW_SOLVE_ISOLATION=docker_pool
CLAW_POOL_HOST_DAEMON=1
CLAW_POOL_DAEMON_SKIP_BUILD=1
CLAW_POOL_DAEMON_BIN=/home/admin/.local/bin/claw-pool-daemon
CLAW_POOL_ADVERTISE_HOST=192.168.9.252

CLAW_DOCKER_POOL_SIZE=4
CLAW_DOCKER_POOL_MIN_IDLE=1

CLAUDE_TAP_MODE=docker
CLAUDE_TAP_IMAGE=ghcr.io/passionke/claude-tap:latest
CLAUDE_TAP_HOST_PORT=8080

CLAW_HOST_LOG_DIR=./deploy/stack/claw-logs

# Optional git sync (token in real .env only)
# CLAW_PROJECTS_GIT_URL=
# CLAW_PROJECTS_GIT_TOKEN=
