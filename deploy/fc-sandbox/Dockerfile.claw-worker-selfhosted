# claw-worker for self-hosted e2bserver (claw + ttyd + NFS client). Author: kejiqing
FROM docker.1ms.run/library/debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    nfs-common \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*
COPY claw /usr/local/bin/claw
COPY ttyd /usr/local/bin/ttyd
RUN chmod +x /usr/local/bin/claw /usr/local/bin/ttyd
