# Base images default to docker.1ms.run; override: podman build --build-arg RUST_BASE_IMAGE=... --build-arg DEBIAN_BASE_IMAGE=...
# Author: kejiqing
ARG RUST_BASE_IMAGE=docker.1ms.run/library/rust:1.88-bookworm
ARG DEBIAN_BASE_IMAGE=docker.1ms.run/library/debian:bookworm-slim

FROM ${RUST_BASE_IMAGE} AS builder

# Default: official rustup. Pass USTC (or other) via build-arg from build.sh when CLAW_USE_CN_RUST_MIRROR=1.
ARG RUSTUP_DIST_SERVER=https://static.rust-lang.org
ARG RUSTUP_UPDATE_ROOT=https://static.rust-lang.org/rustup
ENV RUSTUP_DIST_SERVER=${RUSTUP_DIST_SERVER} \
    RUSTUP_UPDATE_ROOT=${RUSTUP_UPDATE_ROOT}

WORKDIR /build
COPY rust/Cargo.toml /build/Cargo.toml
COPY rust/Cargo.lock /build/Cargo.lock
COPY rust/crates/ /build/crates/
RUN rustup toolchain install nightly && rustup default nightly && \
    cargo build -p rusty-claude-cli --bin claw --release && \
    cargo build -p http-gateway-rs --release

FROM ${DEBIAN_BASE_IMAGE}
# podman: remote client for CLAW_SOLVE_ISOLATION=podman_pool (API socket mounted from host).
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    podman \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /build/target/release/claw /usr/local/bin/claw
COPY --from=builder /build/target/release/http-gateway-rs /usr/local/bin/http-gateway-rs
# Same GHCR image as the gateway: host can `docker|podman run --entrypoint cat … /usr/local/bin/claw-pool-daemon` for pool-daemon-up. Author: kejiqing
COPY --from=builder /build/target/release/claw-pool-daemon /usr/local/bin/claw-pool-daemon

ENV CLAW_HTTP_ADDR=0.0.0.0:8080
ENV CLAW_WORK_ROOT=/var/lib/claw/workspace

RUN mkdir -p /var/lib/claw/workspace /var/log/claw/traces

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/http-gateway-rs"]
