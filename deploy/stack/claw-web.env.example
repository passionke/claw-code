# Claw Web stack (CopilotKit UI + AG-UI bridge + http-gateway-rs). Author: kejiqing
# Merge into repo root `.env` before `./deploy/stack/gateway.sh tap-up`.

# AG-UI bridge (L1) — compose service `ag-ui-bridge`
CLAW_AGUI_BRIDGE_HOST_PORT=8090
CLAW_AGUI_BRIDGE_ADDR=0.0.0.0:8090
CLAW_GATEWAY_BASE_URL=http://127.0.0.1:8088

# CopilotKit Web UI (Phase 1)
CLAW_WEB_UI_PORT=4100
CLAW_AGUI_BRIDGE_URL=http://127.0.0.1:8090
CLAW_WEB_DEFAULT_DS_ID=1

# Claw Web conversation store (PostgreSQL). `./deploy/stack/gateway.sh pg-up` then web-ui.
CLAW_WEB_PG_PORT=5433
CLAW_WEB_PG_USER=claw
CLAW_WEB_PG_PASSWORD=claw
CLAW_WEB_PG_DB=claw_web
CLAW_WEB_DATABASE_URL=postgresql://claw:claw@127.0.0.1:5433/claw_web
# Dev user (PG claw_users.user_id; aligns with L5 JWT sub when auth lands)
CLAW_WEB_DEV_USER_ID=dev-local
# Optional: LLM session titles (OpenAI-compatible). Unset = fallback after first assistant reply.
# CLAW_TITLE_LLM_BASE_URL=https://api.deepseek.com
# CLAW_TITLE_LLM_API_KEY=
# CLAW_TITLE_LLM_MODEL=deepseek-chat
# CLAW_WEB_DEV_TENANT_ID=team-a

# Project center storage (S3-compatible OSS). When set, new projects use storage_protocol=oss.
# CLAW_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# CLAW_OSS_BUCKET=your-bucket
# CLAW_OSS_REGION=oss-cn-hangzhou
# CLAW_OSS_ACCESS_KEY_ID=
# CLAW_OSS_SECRET_ACCESS_KEY=
# CLAW_OSS_FORCE_PATH_STYLE=0

# Dev-only: enables POST /v1/dev/agui/* for ./tests/verify-claw-web.sh --tier full
CLAW_GATEWAY_DEV_AGUI=1

# Phase 2 — code-server (read-only claw-workspace)
# CLAW_CODE_SERVER_ENABLED=1
# CLAW_CODE_SERVER_PORT=4101
# CLAW_CODE_SERVER_PASSWORD=claw

# Optional / historical — OpenCode Web (not primary Claw Web UI)
# OPENCODE_AGENT_BACKEND_URL=http://127.0.0.1:8090

# Optional SaaS (L5)
# CLAW_GATEWAY_AUTH=1
# CLAW_AUTH_DS_TENANT_MAP=1:team-a,2:team-b
