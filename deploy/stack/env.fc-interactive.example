# FC interactive mode overlay — merge into repo root `.env`. Author: kejiqing
#
# Gateway + OVS mount NAS via compose NFS volume (no Mac host NFS mount).
# See deploy/fc-sandbox/README.md for FC template + VPC setup.
#
# Do NOT use ./deploy/stack/claw-workspace as workspace truth in FC mode.

CLAW_INTERACTIVE_BACKEND=fc
CLAW_USE_NAS_VOLUME=auto

# --- NAS (compose NFS volume → Gateway / OVS containers) ---
# Use file-system mount point (xxx.cn-beijing.nas.aliyuncs.com), not ap- access point, for NFSv4.
NAS_BASE_URL=010zgfanzicisudejrm-xqc93.cn-beijing.nas.aliyuncs.com
CLAW_FC_NAS_SERVER=${NAS_BASE_URL}
CLAW_FC_NAS_EXPORT=/
CLAW_NAS_NFS_VERSION=4
# ECS only — after Aliyun console mount to /mnt:
# CLAW_NAS_HOST_MOUNT=/mnt
# Optional: host dir for solve podman pool only (Gateway/OVS ignore this when NAS volume is on)
# CLAW_POOL_WORK_ROOT_BIND_SRC=./deploy/stack/claw-workspace

CLAW_WORKER_UID=1000
CLAW_WORKER_GID=1000

# FC template NAS volume name (console → template advanced → NAS dynamic mount)
# CLAW_FC_NAS_VOLUME_NAME=claw-workspace-vol

# --- FC cloud sandbox (E2B-compatible, cn-beijing) ---
CLAW_FC_API_KEY=e2b_replace_me
# CLAW_FC_API_KEY=${ALIYUN_E2B_TOKEN}
CLAW_FC_API_URL=https://api.cn-beijing.e2b.fc.aliyuncs.com
CLAW_FC_DOMAIN=cn-beijing.e2b.fc.aliyuncs.com
CLAW_FC_TEMPLATE=claw-worker-v1
CLAW_FC_SANDBOX_TIMEOUT_SECS=3600
CLAW_FC_TTYD_PORT=7681
# CLAW_FC_EXEC_HELPER=deploy/fc-sandbox/fc_exec.py

# solve_async unchanged — keep podman pool (local host dir unless remote pool):
# CLAW_SOLVE_ISOLATION=podman_pool
