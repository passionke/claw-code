# GitHub Actions CI variables — configure in repo Settings → Secrets and variables → Actions.
# Full guide: deploy/stack/docs/github-ci-variables.md
# Author: kejiqing
#
# Flow (manual):
#   Actions → claw-ci-deploy → Run workflow
#   jobs: build → deploy → admin-solve-e2e

# ── GitHub Secrets / Variables: REQUIRED for release job deploy step ─────────
# Secret:   CLAW_BOOTSTRAP_LLM_API_KEY=sk-your-key-here
# Variable: CLAW_BOOTSTRAP_LLM_BASE_URL=https://your-provider/compatible-mode/v1

# ── GitHub Variables: optional ──────────────────────────────────────────────
# Variable: CLAW_BOOTSTRAP_LLM_MODEL_NAME=deepseek-v4-flash   # DeepSeek; 勿用 gpt-4o-mini
# CLAW_BOOTSTRAP_LLM_NAME=github-ci-llm
# CLAUDE_TAP_IMAGE=ghcr.io/passionke/claude-tap:latest   # SG runner (workflow default)
# Sunmi CN: crpi-cf9vxpq3n8or17mw.cn-hangzhou.personal.cr.aliyuncs.com/passionke/claw-tap:latest

# ── Langfuse OTEL (optional) ────────────────────────────────────────────────
# CLAW_OTEL_ENABLED=1
# LANGFUSE_PUBLIC_KEY=pk-lf-...          # Secret
# LANGFUSE_SECRET_KEY=sk-lf-...          # Secret
# LANGFUSE_BASE_URL=http://62.72.45.75:8090
# CLAW_OTEL_LOG_PROMPTS=1

# ── In .github/workflows/claw-ci-deploy.yml — override via repo Variables ───
CLAW_POOL_ADVERTISE_HOST=62.72.45.75
CLAW_CLUSTER_ID=github-ci-01
CLAW_POOL_ID=pool-github-ci-01
CLAW_CI_NODE_B_POOL_ID=pool-github-ci-02
CLAW_DEPLOY_PROFILE=production
CLAW_CONTAINER_RUNTIME=docker
CLAW_IMAGE_PREFIX=local
CLAW_RELEASE_SKIP_PULL=1
CLAW_AUTO_BOOTSTRAP=1
# SG runner: 0 (crates.io). Sunmi CN runner: 1 (rsproxy).
CLAW_USE_CN_CRATES_MIRROR=0
CLAW_USE_CN_RUST_MIRROR=0
CONTAINER_BASE_REGISTRY=docker.1ms.run

# ── Exposed ports on 62.72.45.75 (firewall) ─────────────────────────────────
# Admin /admin: GATEWAY_PLAYGROUND_HOST_PORT=18765  (opened)
# clawTap Live: CLAUDE_TAP_PUBLISH_LIVE=0.0.0.0:3000:3000  (opened)
# Gateway API: GATEWAY_HOST_PORT=18088  (NOT exposed externally; localhost + e2e only)

# ── Generated defaults (render-env-from-ci.sh) ───────────────────────────────
# GATEWAY_HOST_PORT=18088
# GATEWAY_PLAYGROUND_HOST_PORT=18765
# CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@postgres:5432/claw_gateway
# CLAUDE_TAP_MODE=docker
# CLAUDE_TAP_DOCKER_NETWORK=claw_default
