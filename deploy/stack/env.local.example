# macOS + Podman local dev — merge into repo root `.env`
#   cp deploy/stack/env.local.example .env
#   ./deploy/stack/gateway.sh quick
# Author: kejiqing
#
# tap / worker / gateway 网络默认值在 env-profile.sh（Darwin 自动 claw_default + docker tap）。
# macOS：env-profile 自动 CLAW_WORKER_UID/GID=宿主机 uid（bind mount + gateway compose）；勿在 .env 手写 1000。
# 远程沙箱见 docs/local-dev-remote-backend.md。

CLAW_DEPLOY_PROFILE=local
CLAW_CLUSTER_ID=local-dev

GATEWAY_PLAYGROUND_HOST_PORT=18765
PLAYGROUND_PUBLIC_GATEWAY_BASE=http://127.0.0.1:18088

# solve / gateway-solve-once 超时（秒）；默认 15min
CLAW_TIMEOUT_SECONDS=900
