# macOS + Podman local dev — merge into repo root `.env`
#   cp deploy/stack/env.local.example .env
#   ./deploy/stack/gateway.sh pack-deploy local
# Author: kejiqing

CLAW_DEPLOY_PROFILE=local

# --- LLM (optional bootstrap; normally from Admin → PG sync) ---
# First-time dev without Admin: uncomment until PG has an active LLM model.
# OPENAI_API_KEY=
# UPSTREAM_OPENAI_BASE_URL=

# --- optional: default git commit author for per-ds gitSync push ---
# CLAW_PROJECTS_GIT_AUTHOR=kejiqing <kejiqing@local>

# --- optional ---
# PLAYGROUND_ADMIN_PASSWORD=sunmi123
# CLAW_MCP_MAX_CONCURRENT=12
