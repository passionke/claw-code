# Package pre-built Linux binaries (see deploy/stack/lib/linux-compile.sh). No cargo in image build.
# Author: kejiqing
ARG DEBIAN_BASE_IMAGE=docker.1ms.run/library/debian:bookworm-slim

FROM ${DEBIAN_BASE_IMAGE}
COPY deploy/stack/debian-bookworm-ustc.sources /tmp/debian-cn.sources
ARG CLAW_USE_CN_APT_MIRROR=0
RUN if [ "${CLAW_USE_CN_APT_MIRROR}" = "1" ]; then \
      cp /tmp/debian-cn.sources /etc/apt/sources.list.d/debian.sources; \
    fi; \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    podman \
    docker.io \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY deploy/stack/.linux-artifacts/release/claw /usr/local/bin/claw
COPY deploy/stack/.linux-artifacts/release/http-gateway-rs /usr/local/bin/http-gateway-rs
# claw-vscode VSIX for FC OVS bootstrap (package-claw-vscode-vsix.sh before image build). kejiqing
COPY deploy/stack/claw.claw-vscode-*.vsix /app/deploy/stack/
COPY deploy/fc-sandbox/fc_exec.py deploy/fc-sandbox/fc-nas-bootstrap.sh /app/deploy/fc-sandbox/
# Self-hosted e2b exec helper (CLAW_FC_EXEC_HELPER default). Author: kejiqing
RUN pip3 install --no-cache-dir --break-system-packages e2b e2b-code-interpreter \
    && chmod +x /app/deploy/fc-sandbox/fc_exec.py
# Artifact upload may drop +x; enforce before ENTRYPOINT. kejiqing
RUN chmod +x /usr/local/bin/claw /usr/local/bin/http-gateway-rs
# Host pool: claw-sandbox from linux-compile (.linux-artifacts/release/claw-sandbox), not in gateway image. kejiqing

ENV CLAW_HTTP_ADDR=0.0.0.0:8080
ENV CLAW_WORK_ROOT=/var/lib/claw/workspace
ENV CLAW_FC_EXEC_HELPER=/app/deploy/fc-sandbox/fc_exec.py

RUN mkdir -p /var/lib/claw/workspace /var/log/claw/traces

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/http-gateway-rs"]
