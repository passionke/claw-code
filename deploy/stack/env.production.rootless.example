# Snippet for Aliyun / rootless podman — merge into repo root `.env`.
# Then: ./deploy/stack/gateway.sh up --release release-vX.Y.Z
# Author: kejiqing

CLAW_CONTAINER_RUNTIME=podman
# Run: podman info --format '{{.Host.RemoteSocket.Path}}'
CLAW_CONTAINER_SOCKET=/run/user/1000/podman/podman.sock

CLAW_IMAGE_REGISTRY=acr
CLAW_GATEWAY_PG_IMAGE=docker.io/library/postgres:17-alpine

CLAW_PROJECTS_GIT_URL=
CLAW_PROJECTS_GIT_BRANCH=main
CLAW_PROJECTS_GIT_AUTHOR=kejiqing <kejiqing@local>

OPENAI_API_KEY=
OPENAI_BASE_URL=
