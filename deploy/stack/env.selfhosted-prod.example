# Self-hosted production — copy to repo root `.env` and edit anchors only. Author: kejiqing
#
# Per-environment values live ONLY in the anchor block below.
# Run after edit: ./deploy/stack/gateway.sh sync-e2b-env --restart --nginx

CLAW_DEPLOY_PROFILE=local
CLAW_CONTAINER_RUNTIME=docker
CLAW_CLUSTER_ID=passionke_claw_prod

# === Infra anchors（换环境只改这里）===
CLAW_E2B_HOST=10.66.0.3
CLAW_E2B_API_PORT=3000
CLAW_E2B_SANDBOX_PORT=3002
CLAW_E2B_TRAFFIC_PORT=3001
# wildcard DNS 须解析到 CLAW_E2B_HOST（例：*.supone.online → 10.66.0.3）
CLAW_E2B_DOMAIN=supone.online
CLAW_E2B_SERVER_ROOT=/root/work/e2bserver

CLAW_PG_HOST=db.supone.online
CLAW_PG_PORT=5432
CLAW_PG_USER=claw_gateway
CLAW_PG_PASSWORD=change-me
CLAW_PG_DATABASE=claw_gateway

# Gateway 对外宣告 IP；与 e2b 同机时可省略（默认 = CLAW_E2B_HOST）
# CLAW_POOL_ADVERTISE_HOST=10.66.0.3
GATEWAY_HOST_PORT=8088
GATEWAY_PLAYGROUND_HOST_PORT=18765

# 无 NFS：e2b 宿主机本地 bind 根（sync-e2b-env → e2bserver [nas].host_mount_root）
CLAW_E2B_NAS_HOST_MOUNT=/data/claw-nas
CLAW_USE_NAS_VOLUME=0
# 有 NFS 时另设：CLAW_E2B_NAS_SERVER= CLAW_E2B_NAS_EXPORT=

CLAW_E2B_API_KEY=e2b_replace_me
CLAW_E2B_TRAFFIC_NGINX=1
CLAW_E2B_OBSERVE_E2B_PUSH=0

# === Derived（勿写死 IP/域名）===
CLAW_POOL_ADVERTISE_HOST=${CLAW_POOL_ADVERTISE_HOST:-${CLAW_E2B_HOST}}
CLAW_GATEWAY_DATABASE_URL=postgres://${CLAW_PG_USER}:${CLAW_PG_PASSWORD}@${CLAW_PG_HOST}:${CLAW_PG_PORT}/${CLAW_PG_DATABASE}
CLAW_E2B_SANDBOX_DATABASE_URL=postgres://${CLAW_PG_USER}:${CLAW_PG_PASSWORD}@${CLAW_PG_HOST}:${CLAW_PG_PORT}/${CLAW_PG_DATABASE}
CLAW_E2B_API_URL=http://${CLAW_E2B_HOST}:${CLAW_E2B_API_PORT}
CLAW_E2B_SANDBOX_URL=http://${CLAW_E2B_HOST}:${CLAW_E2B_SANDBOX_PORT}
CLAW_E2B_DEV_WORKER_HOST=${CLAW_E2B_HOST}
PLAYGROUND_PUBLIC_GATEWAY_BASE=http://${CLAW_POOL_ADVERTISE_HOST}:${GATEWAY_HOST_PORT}
CLAW_TAP_TRACES_DIR=${CLAW_E2B_NAS_HOST_MOUNT}/tap-traces

# === e2b / gateway 行为 ===
CLAW_INTERACTIVE_BACKEND=e2b
CLAW_OVS_BACKEND=e2b
CLAW_SOLVE_ISOLATION=e2b
CLAUDE_TAP_MODE=off
CLAW_E2B_TEMPLATE=claw-worker
CLAW_E2B_OVS_TEMPLATE=claw-ovs
CLAW_E2B_OBSERVE_TEMPLATE=claw-observe
CLAW_E2B_SANDBOX_TIMEOUT_SECS=3600
CLAW_E2B_PROJECT_WORKER_TTL_SECS=3600
CLAW_E2B_WORKER_ARCH=amd64
CLAW_WORKER_UID=1000
CLAW_WORKER_GID=1000
CLAW_TIMEOUT_SECONDS=1800

# === LLM bootstrap ===
CLAW_BOOTSTRAP_LLM_API_KEY=
CLAW_BOOTSTRAP_LLM_BASE_URL=https://api.deepseek.com/v1
CLAW_BOOTSTRAP_LLM_MODEL_NAME=deepseek-v4-pro
CLAW_BOOTSTRAP_LLM_NAME=deepseek-prod
CLAW_AUTO_BOOTSTRAP=1

# === Admin ===
PLAYGROUND_ADMIN_USER=admin
PLAYGROUND_ADMIN_PASSWORD=change-me
