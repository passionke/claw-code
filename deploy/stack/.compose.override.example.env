# Optional second file for `podman compose --env-file ../../.env --env-file .compose.override.example.env`
# Example: set a global tool allowlist to test request `allowedTools` intersection.
# Author: kejiqing
GATEWAY_IMAGE=localhost/claw-gateway-rs:local
GATEWAY_HOST_PORT=18088
CLAW_TIMEOUT_SECONDS=120
CLAW_LOG_LEVEL=info
CLAW_TRACE_ENABLED=1
CLAW_HOST_LOG_DIR=./claw-logs
# CLAW_ALLOWED_TOOLS=read_file,glob_search
