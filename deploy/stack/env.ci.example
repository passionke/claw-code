# GitLab CI — do NOT copy to repo .env on the runner.
# Set these as job `variables:` or CI/CD → Variables; then:
#   ./deploy/stack/lib/render-env-from-ci.sh
#   ./deploy/stack/gateway.sh up --release release-xxx
# Or one shot: ./deploy/stack/lib/ci-release-deploy.sh
# Author: kejiqing

# Required (per machine)
CLAW_POOL_ADVERTISE_HOST=10.22.28.94
CLAW_CLUSTER_ID=sunmi-ci-01

# Recommended
CLAW_DEPLOY_PROFILE=production
CLAW_CONTAINER_RUNTIME=docker
CLAW_IMAGE_PREFIX=local
CLAW_POOL_ID=pool-sunmi-ci-01
CLAW_RELEASE_SKIP_PULL=1
CLAW_AUTO_BOOTSTRAP=1

# LLM bootstrap (GitLab CI/CD Variables, masked — written into .env by render-env-from-ci.sh):
# CLAW_BOOTSTRAP_LLM_API_KEY=sk-...
# CLAW_BOOTSTRAP_LLM_BASE_URL=https://your-llm/v1
# CLAW_BOOTSTRAP_LLM_MODEL_NAME=gpt-4o-mini

# Optional overrides
# GATEWAY_HOST_PORT=18088
# CLAW_GATEWAY_DATABASE_URL=postgres://...
# CLAUDE_TAP_PUBLISH_LIVE=0.0.0.0:3000:3000
