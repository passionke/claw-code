# GitLab CI variables — configure in code.sunmi.com UI, NOT as a runner .env file.
# Full guide: deploy/stack/docs/gitlab-ci-variables.md
# Author: kejiqing
#
# Flow:
#   Settings → CI/CD → Variables  (see section 1 in doc)
#   pipeline: build:release-images → deploy:release (manual)

# ── GitLab UI: REQUIRED (Masked) for deploy:release ─────────────────────────
# CLAW_BOOTSTRAP_LLM_API_KEY=sk-your-key-here
# CLAW_BOOTSTRAP_LLM_BASE_URL=https://your-provider/compatible-mode/v1

# ── GitLab UI: optional ─────────────────────────────────────────────────────
# CLAW_BOOTSTRAP_LLM_MODEL_NAME=qwen-plus
# CLAW_BOOTSTRAP_LLM_NAME=sunmi-ci-llm
# CLAUDE_TAP_IMAGE=crpi-cf9vxpq3n8or17mw.cn-hangzhou.personal.cr.aliyuncs.com/passionke/claw-tap:latest

# ── In .gitlab-ci.yml (ci_production_docker) — override in UI if another host ─
CLAW_POOL_ADVERTISE_HOST=10.22.28.94
CLAW_CLUSTER_ID=sunmi-ci-01
CLAW_POOL_ID=pool-sunmi-ci-01
CLAW_DEPLOY_PROFILE=production
CLAW_CONTAINER_RUNTIME=docker
CLAW_IMAGE_PREFIX=local
CLAW_RELEASE_SKIP_PULL=1
CLAW_AUTO_BOOTSTRAP=1
CLAW_USE_CN_CRATES_MIRROR=1

# ── Generated defaults (render-env-from-ci.sh) ───────────────────────────────
# GATEWAY_HOST_PORT=18088
# GATEWAY_PLAYGROUND_HOST_PORT=18765
# CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@postgres:5432/claw_gateway
# CLAUDE_TAP_MODE=docker
# CLAUDE_TAP_DOCKER_NETWORK=claw_default
# CLAUDE_TAP_PUBLISH_PROXY=0
