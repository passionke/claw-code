# Self-hosted e2b + NFS interactive overlay — merge into repo root `.env`. Author: kejiqing
#
# Canonical infra addresses: docs/architecture-governance.md §1
# NAS layout (Gateway 不直连 NAS，走 claw-nas-api): docs/fc-nas-workspace.md
#
# Prereq: host on WireGuard 10.8.0.0/24 (Mac / 234 ECS wg0).

CLAW_INTERACTIVE_BACKEND=fc
CLAW_OVS_BACKEND=fc
CLAW_USE_NAS_VOLUME=0
# FC: worker 内 tap proxy + e2b observe singleton；不要起 compose claw-claude-tap
CLAUDE_TAP_MODE=off

# --- Self-hosted NFS (10.8.0.11) ---
# e2b 宿主机: mount -t nfs -o vers=4.2,_netdev 10.8.0.11:/ /mnt/nas0
NAS_BASE_URL=10.8.0.11
CLAW_FC_NAS_SERVER=10.8.0.11
CLAW_FC_NAS_EXPORT=/
CLAW_NAS_NFS_VERSION=4
CLAW_NAS_NFS_MINOR=2
# e2b 宿主机 NAS 挂载点 → nasConfig.hostMountRoot（Gateway 本机不挂 NAS，仅排查时可 mount）
CLAW_E2B_NAS_HOST_MOUNT=/mnt/nas0
CLAW_TAP_TRACES_DIR=/mnt/nas0/tap-traces
# CLAW_NAS_HOST_MOUNT — Gateway 不直连 NAS；勿设。见 architecture-governance.md §2
# CLAW_POOL_WORK_ROOT_BIND_SRC — 已废弃（宿主机 pool 已移除）

CLAW_WORKER_UID=1000
CLAW_WORKER_GID=1000

# --- Self-hosted e2bserver (10.8.0.1, NOT Aliyun FC) ---
CLAW_FC_API_KEY=e2b_53ae1fed82754c17ad8077fbc8bcdd90
CLAW_FC_API_URL=http://10.8.0.1:3000
CLAW_E2B_SANDBOX_URL=http://10.8.0.1:3002
CLAW_FC_DOMAIN=supone.top
# Browser traffic: http://{port}-{sandboxId}.supone.top/ (wildcard DNS). See Affine「Traffic 访问说明」.
CLAW_FC_TRAFFIC_PORT=3001
CLAW_FC_TEMPLATE=claw-worker
CLAW_FC_OVS_TEMPLATE=claw-ovs
CLAW_FC_OVS_PORT=3000
CLAW_FC_OBSERVE_TEMPLATE=claw-observe
CLAW_FC_OBSERVE_LIVE_PORT=3000
# CLAW_FC_OBSERVE=0   # disable e2b session-observe singleton (Admin Live stays compose/local)
CLAW_FC_SANDBOX_TIMEOUT_SECS=3600
# Per-project worker renew TTL (solve + OVS shared worker; defaults to CLAW_FC_SANDBOX_TIMEOUT_SECS).
CLAW_FC_PROJECT_WORKER_TTL_SECS=3600
# Optional renew tick (default: ttl/6, min 120s — e.g. 600 for 1h TTL).
# CLAW_FC_PROJECT_WORKER_RENEW_INTERVAL_SECS=600
CLAW_FC_TTYD_PORT=7681
# Template builds (require non-empty startCmd on e2bserver):
# Must use e2b standard template build paths only. Do not set
# CLAW_E2B_TEMPLATE_HTTP_* / CLAW_FC_TEMPLATE_HTTP_* or any dockerfile-http strategy.
#   python3 deploy/fc-sandbox/build-claw-worker-selfhosted.py
#   python3 deploy/fc-sandbox/build-claw-ovs-selfhosted.py
#   python3 deploy/fc-sandbox/build-claw-observe-selfhosted.py
#   python3 deploy/fc-sandbox/build-claw-nas-api-selfhosted.py
# FC singletons (after templates ready):
#   ./deploy/stack/gateway.sh nas-api-up --reuse --json
#   ./deploy/stack/gateway.sh ovs-up --reuse --json
#   ./deploy/stack/gateway.sh observe-tap-up --reuse --json

# FC interactive warm pool (project-bound; bake /claw_ds before idle)
CLAW_FC_POOL_MIN_IDLE=1
CLAW_FC_POOL_SIZE_CAP=4

# solve + interactive: FC-only
CLAW_SOLVE_ISOLATION=fc

# compose OVS disabled when CLAW_OVS_BACKEND=fc (OVS on e2b singleton)
