# Self-hosted e2b + NFS interactive overlay — merge into repo root `.env`. Author: kejiqing
#
# Production / multi-cluster: prefer deploy/stack/env.selfhosted-prod.example (anchor block + sync-e2b-env).
# Canonical infra addresses: docs/architecture-governance.md §1
# NAS layout (Gateway 不直连 NAS，走 claw-nas-api): docs/e2b-nas-workspace.md
#
# Prereq: host on WireGuard 10.8.0.0/24 (Mac / 234 ECS wg0).

CLAW_USE_NAS_VOLUME=0

# --- Self-hosted NFS (10.8.0.11) ---
# e2b 宿主机: mount -t nfs -o vers=4.2,_netdev 10.8.0.11:/ /mnt/nas0
NAS_BASE_URL=10.8.0.11
CLAW_E2B_NAS_SERVER=10.8.0.11
CLAW_E2B_NAS_EXPORT=/
CLAW_NAS_NFS_VERSION=4
CLAW_NAS_NFS_MINOR=2
# e2b 宿主机 NAS 挂载点 → nasConfig.hostMountRoot（Gateway 本机不挂 NAS，仅排查时可 mount）
CLAW_E2B_NAS_HOST_MOUNT=/mnt/nas0
CLAW_TAP_TRACES_DIR=/mnt/nas0/tap-traces
# CLAW_NAS_HOST_MOUNT — Gateway 不直连 NAS；勿设。见 architecture-governance.md §2
# CLAW_POOL_WORK_ROOT_BIND_SRC — 已废弃（宿主机 pool 已移除）

CLAW_WORKER_UID=1000
CLAW_WORKER_GID=1000

# --- Self-hosted e2bserver (10.8.0.1) ---
CLAW_E2B_API_KEY=e2b_53ae1fed82754c17ad8077fbc8bcdd90
CLAW_E2B_API_URL=http://10.8.0.1:3000
CLAW_E2B_SANDBOX_URL=http://10.8.0.1:3002
CLAW_E2B_DOMAIN=supone.top
# DNS: apex supone.top + *.supone.top → e2b (template upload URLs use http://supone.top:3000/…)
# Browser traffic: http://{port}-{sandboxId}.supone.top/
CLAW_E2B_TRAFFIC_PORT=3001
CLAW_E2B_TEMPLATE=claw-worker
CLAW_E2B_OVS_TEMPLATE=claw-ovs
CLAW_E2B_OVS_PORT=3000
CLAW_E2B_OBSERVE_TEMPLATE=claw-observe
CLAW_E2B_OBSERVE_LIVE_PORT=3000
# CLAW_E2B_OBSERVE=0   # disable e2b session-observe singleton (Admin Live stays compose/local)
CLAW_E2B_SANDBOX_TIMEOUT_SECS=3600
# Per-project worker renew TTL (solve + OVS shared worker; defaults to CLAW_E2B_SANDBOX_TIMEOUT_SECS).
CLAW_E2B_PROJECT_WORKER_TTL_SECS=3600
# Optional renew tick (default: ttl/6, min 120s — e.g. 600 for 1h TTL).
# CLAW_E2B_PROJECT_WORKER_RENEW_INTERVAL_SECS=600
CLAW_E2B_TTYD_PORT=7681
# --- e2b worker arch (self-hosted fleet = linux/amd64 on 10.8.0.1 / 10.8.0.2) ---
CLAW_E2B_WORKER_ARCH=amd64
CLAW_E2B_DEV_WORKER_HOST=10.8.0.2
# Build + PG persist: ./deploy/stack/gateway.sh e2b-worker-deploy
# See deploy/e2b/WORKER-BUILD.md
#   python3 deploy/e2b/build-claw-ovs-selfhosted.py
#   python3 deploy/e2b/build-claw-observe-selfhosted.py
#   python3 deploy/e2b/build-claw-nas-api-selfhosted.py
# e2b singletons (after templates ready):
#   ./deploy/stack/gateway.sh nas-api-up --reuse --json
#   ./deploy/stack/gateway.sh ovs-up --reuse --json
#   ./deploy/stack/gateway.sh observe-tap-up --reuse --json

# e2b interactive warm pool (project-bound; bake /claw_ds before idle)
CLAW_E2B_POOL_MIN_IDLE=1
CLAW_E2B_POOL_SIZE_CAP=4

# solve + interactive: e2b-only
CLAW_SOLVE_ISOLATION=e2b

# --- Unified PostgreSQL (250) — one DB; distinguish envs via CLAW_CLUSTER_ID ---
# CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:<password>@192.168.9.250:5432/claw_gateway
# CLAW_E2B_WORKER_DATABASE_URL=postgres://claw_gateway:<password>@192.168.9.250:5432/claw_gateway
# Mac dev: CLAW_CLUSTER_ID=local-dev ; pre-252: CLAW_CLUSTER_ID=prod-claw-252
# Do not run compose postgres (gateway.sh skips pg-up when URL is external).

# compose OVS disabled (OVS on e2b singleton)
