# 192.168.9.252 pre-prod — gateway + Admin (e2b on 250, PG on 250)
# Copy: cp deploy/stack/env.pre-252.e2b.example .env  then fill secrets.
# Start: ./deploy/stack/gateway.sh up --release release-vX.Y.Z
# Author: kejiqing

CLAW_DEPLOY_PROFILE=production
CLAW_CLUSTER_ID=prod-claw-252

# --- Gateway + Admin (252) ---
GATEWAY_HOST_PORT=18088
GATEWAY_PLAYGROUND_HOST_PORT=18765
CLAW_POOL_ADVERTISE_HOST=192.168.9.252
PLAYGROUND_PUBLIC_GATEWAY_BASE=http://192.168.9.252:18088
CLAW_GATEWAY_PUBLIC_HOST=192.168.9.252:18088

CLAW_CONTAINER_RUNTIME=docker
CLAW_IMAGE_REGISTRY=acr
CLAW_TIMEOUT_SECONDS=1800

# --- PostgreSQL (250) ---
# CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:<password>@192.168.9.250:5432/claw_gateway

# --- e2bserver (250) — use panel api_key, NOT worker_token ---
# CLAW_E2B_API_URL=http://192.168.9.250:3000
# CLAW_E2B_SANDBOX_URL=http://192.168.9.250:3002
# CLAW_E2B_API_KEY=e2b_...
CLAW_E2B_DOMAIN=supone.top
CLAW_E2B_TEMPLATE=claw-worker
CLAW_E2B_NAS_API_TEMPLATE=claw-nas-api
CLAW_E2B_OVS_TEMPLATE=claw-ovs
CLAW_E2B_OBSERVE_TEMPLATE=claw-observe
CLAW_E2B_SANDBOX_TIMEOUT_SECS=3600
CLAW_E2B_PROJECT_WORKER_TTL_SECS=3600

# NAS on e2b host (250): must match e2bserver config.toml [nas].host_mount_root
# CLAW_E2B_NAS_HOST_MOUNT=/data/claw-nas

# LLM bootstrap until Admin → PG (do not commit real keys)
# CLAW_AUTO_BOOTSTRAP=1
# UPSTREAM_OPENAI_BASE_URL=https://your-llm-gw/v1
# OPENAI_API_KEY=
# CLAW_BOOTSTRAP_LLM_API_KEY=
# CLAW_BOOTSTRAP_LLM_BASE_URL=
# CLAW_DEFAULT_MODEL=openai/qwen3-max

# Images: use release pin — do NOT set GATEWAY_IMAGE=:local here
# ./deploy/stack/gateway.sh up --release release-vX.Y.Z

CLAW_HOST_LOG_DIR=./deploy/stack/claw-logs

# Optional Admin login (defaults in compose if unset)
# PLAYGROUND_ADMIN_USER=admin
# PLAYGROUND_ADMIN_PASSWORD=
