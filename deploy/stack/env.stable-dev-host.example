# 稳定开发后端（与 GitLab CI 隔离）— 10.22.28.94 等 Linux 宿主机
#   cp deploy/stack/env.stable-dev-host.example .env.dev-stable
#   ./deploy/stack/gateway.sh build local          # 首次：编译 claw-sandbox + worker 镜像
#   ./deploy/stack/lib/stable-dev-host-up.sh
# Author: kejiqing
#
# 端口与 CI 错开：PG 5434 / pool 9954 / tap 代理 8081 / tap Live 3001

CLAW_DEPLOY_PROFILE=production
CLAW_CONTAINER_RUNTIME=docker
CLAW_CLUSTER_ID=dev-stable
CLAW_POOL_ID=pool-dev-stable
CLAW_POOL_ADVERTISE_HOST=10.22.28.94
CLAW_POOL_HTTP_PORT=9954
CLAW_POOL_HTTP_BIND=0.0.0.0:9954
CLAW_POOL_HOST_DAEMON=1
CLAW_POOL_DAEMON_USE_SYSTEMD=1
CLAW_POOL_DAEMON_SKIP_BUILD=1
CLAW_SOLVE_ISOLATION=docker_pool
CLAW_DOCKER_IMAGE=claw-gateway-worker:local
CLAW_RELAXED_DOCKER_IMAGE=claw-gateway-worker-relaxed:local
CLAW_STRICT_DOCKER_POOL_SIZE=4
CLAW_STRICT_DOCKER_POOL_MIN_IDLE=1
CLAW_RELAXED_DOCKER_POOL_SIZE=1
CLAW_ALLOW_RELAXED_WORKER=true

COMPOSE_PROJECT_NAME=claw-dev-stable
CLAW_COMPOSE_PG_CONTAINER=claw-dev-stable-postgres
CLAW_GATEWAY_PG_HOST_PORT=5434
CLAW_PG_DATA_DIR=./claw-postgres-data-dev-stable
CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@127.0.0.1:5434/claw_gateway
CLAW_POOL_DAEMON_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@127.0.0.1:5434/claw_gateway

CLAW_STACK_INSTANCE=dev-stable
CLAW_POOL_RPC_INSTANCE=dev-stable

CLAUDE_TAP_MODE=docker
CLAUDE_TAP_IMAGE=crpi-cf9vxpq3n8or17mw.cn-hangzhou.personal.cr.aliyuncs.com/passionke/claw-tap:latest
CLAUDE_TAP_CONTAINER_NAME=claw-claude-tap-dev-stable
CLAUDE_TAP_PUBLISH_PROXY=0.0.0.0:8081:8080
# Live 对 LAN 开放（模式 B Mac Admin 填 10.22.28.94:3001）；仅本机调试可改 127.0.0.1:3001:3000
CLAUDE_TAP_PUBLISH_LIVE=0.0.0.0:3001:3000
# 独立 tap，不挂 CI 的 claw_default 网络
# CLAUDE_TAP_DOCKER_NETWORK=
CLAW_TAP_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@172.17.0.1:5434/claw_gateway

# Bootstrap LLM（tap / Admin 写入 PG）
# OPENAI_API_KEY=sk-...
# UPSTREAM_OPENAI_BASE_URL=https://your-provider/v1
