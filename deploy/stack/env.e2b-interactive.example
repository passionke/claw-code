# Interactive mode overlay — **prefer** `env.selfhosted-e2b.example` (e2b 10.8.0.1 + NAS 10.8.0.11).
# NAS 路径契约：docs/e2b-nas-workspace.md
# This file kept for Aliyun e2b reference only. Author: kejiqing
#
# Self-hosted (recommended): deploy/stack/env.selfhosted-e2b.example
# Aliyun e2b (legacy): values below.

CLAW_USE_NAS_VOLUME=auto

# --- NAS (compose NFS volume → Gateway / OVS containers) ---
# Use file-system mount point (xxx.cn-beijing.nas.aliyuncs.com), not ap- access point, for NFSv4.
NAS_BASE_URL=010zgfanzicisudejrm-xqc93.cn-beijing.nas.aliyuncs.com
CLAW_E2B_NAS_SERVER=${NAS_BASE_URL}
CLAW_E2B_NAS_EXPORT=/
CLAW_NAS_NFS_VERSION=4
# ECS only — after Aliyun console mount to /mnt:
# CLAW_NAS_HOST_MOUNT=/mnt
# Pool tap traces (default ${CLAW_NAS_HOST_MOUNT}/tap-traces when NAS mounted):
# CLAW_TAP_TRACES_DIR=/mnt/tap-traces
# Optional: host dir for solve podman pool only (Gateway/OVS ignore this when NAS volume is on)
# CLAW_POOL_WORK_ROOT_BIND_SRC=./deploy/stack/claw-workspace

CLAW_WORKER_UID=1000
CLAW_WORKER_GID=1000

# e2b template NAS volume name — legacy only (custom template + console pre-register).
# Legacy removed: CLAW_E2B_NAS_VOLUME_NAME (use nasConfig bind via gateway pool)

# --- e2b cloud sandbox (E2B-compatible, cn-beijing) ---
CLAW_E2B_API_KEY=e2b_replace_me
# CLAW_E2B_API_KEY=${ALIYUN_E2B_TOKEN}
CLAW_E2B_API_URL=https://api.cn-beijing.e2b.fc.aliyuncs.com
CLAW_E2B_DOMAIN=cn-beijing.e2b.fc.aliyuncs.com
CLAW_E2B_TEMPLATE=code-interpreter-v1
CLAW_E2B_SANDBOX_TIMEOUT_SECS=3600
CLAW_E2B_TTYD_PORT=7681
# PG URL reachable from e2b sandbox VPN (required for worker-embedded claude-tap):
# CLAW_E2B_WORKER_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@10.8.0.10:5433/claw_gateway
# CLAW_E2B_EXEC_HELPER=deploy/e2b/e2b_exec.py
# claw/ttyd: only in e2b template (build-claw-worker-selfhosted.py after pack-deploy)

# solve_async + interactive: e2b-only (see docs/http-gateway-container-pool.md)
