# Gateway async playground (stdlib Python + Vite admin SPA). Author: kejiqing
# Runtime: debian:bookworm-slim + python3 (official python:* tags often missing on docker.1ms.run).
ARG DEBIAN_BASE_IMAGE=docker.1ms.run/library/debian:bookworm-slim
ARG NODE_BASE_IMAGE=docker.1ms.run/library/node:20-alpine
ARG CLAW_USE_CN_APT_MIRROR=0

FROM ${NODE_BASE_IMAGE} AS admin-build
WORKDIR /build
COPY web/gateway-admin/package.json web/gateway-admin/package-lock.json ./
RUN npm config set registry https://registry.npmmirror.com \
  && npm ci
COPY web/gateway-admin/ ./
RUN npm run build \
  && test -f dist/index.html \
  && sh -c 'test -n "$(ls dist/assets/*.js 2>/dev/null)"'

FROM ${DEBIAN_BASE_IMAGE}
ARG CLAW_USE_CN_APT_MIRROR=0
COPY deploy/stack/debian-bookworm-ustc.sources /tmp/debian-cn.sources
RUN if [ "${CLAW_USE_CN_APT_MIRROR}" = "1" ]; then \
      cp /tmp/debian-cn.sources /etc/apt/sources.list.d/debian.sources; \
    fi; \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY web/gateway-async-playground/server.py \
     web/gateway-async-playground/index.html \
     web/gateway-async-playground/coding.html \
     ./
COPY --from=admin-build /build/dist/ ./admin-dist/

ENV PLAYGROUND_ADMIN_DIST=/app/admin-dist \
    PLAYGROUND_LISTEN_HOST=0.0.0.0 \
    PLAYGROUND_LISTEN_PORT=18765 \
    PLAYGROUND_GATEWAY_BASE=http://gateway-rs:8080 \
    PLAYGROUND_PUBLIC_GATEWAY_BASE=http://127.0.0.1:8088 \
    PLAYGROUND_ALLOWED_HOSTS=127.0.0.1,localhost,gateway-rs \
    PLAYGROUND_ALLOWED_PORTS=8080,8088,18088

EXPOSE 18765
CMD ["python3", "server.py"]
