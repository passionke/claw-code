# DEPRECATED — local profile is podman-only. Use env.local.example or install podman on Linux.
# For Docker-only Linux hosts doing pack-deploy, use CLAW_DEPLOY_PROFILE=production patterns instead.
#
# Linux + Docker local pack-deploy (gitlab-runner / sunmax-i5) — no longer supported.
#   cp deploy/stack/env.local.linux-docker.example .env
#   ./deploy/stack/gateway.sh pack-deploy local
#
# Human .env = deploy identity only. LLM/tap upstream → Admin (PG).
# Tap publish (Live 3000 / proxy 8080) → env-profile defaults for local+docker.
# Live viewer: http://<host>:3000/  (Admin clawTap host still claw-claude-tap)
# Author: kejiqing

CLAW_DEPLOY_PROFILE=local
CLAW_CLUSTER_ID=sunmi-dev-01

CLAW_CONTAINER_RUNTIME=docker
CLAW_USE_CN_CRATES_MIRROR=1
CONTAINER_BASE_REGISTRY=docker.1ms.run

GATEWAY_HOST_PORT=18088
GATEWAY_PLAYGROUND_HOST_PORT=18765
CLAW_TIMEOUT_SECONDS=1800

CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@postgres:5432/claw_gateway
CLAW_GATEWAY_PG_HOST_PORT=5433
