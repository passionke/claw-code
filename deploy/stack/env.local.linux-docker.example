# Linux + Docker local pack-deploy (gitlab-runner / sunmax-i5)
#   cp deploy/stack/env.local.linux-docker.example .env
#   ./deploy/stack/gateway.sh pack-deploy local
# Author: kejiqing

CLAW_DEPLOY_PROFILE=local
CLAW_CLUSTER_ID=sunmi-dev-01

CLAW_CONTAINER_RUNTIME=docker
CLAW_SOLVE_ISOLATION=docker_pool
CLAW_USE_CN_CRATES_MIRROR=1
CONTAINER_BASE_REGISTRY=docker.1ms.run

GATEWAY_HOST_PORT=18088
GATEWAY_PLAYGROUND_HOST_PORT=18765
PLAYGROUND_PUBLIC_GATEWAY_BASE=http://127.0.0.1:18088
CLAW_TIMEOUT_SECONDS=1800

CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@postgres:5432/claw_gateway
CLAW_GATEWAY_PG_HOST_PORT=5433

# claude-tap (Linux docker — do not use native on gitlab-runner)
COMPOSE_PROJECT_NAME=claw
CLAUDE_TAP_MODE=docker
CLAUDE_TAP_IMAGE=ghcr.io/passionke/claude-tap:latest
CLAUDE_TAP_DOCKER_NETWORK=claw_default
CLAUDE_TAP_PUBLISH_PROXY=0
CLAW_DOCKER_NETWORK=claw_default

# Bootstrap until Admin → PG has active LLM (copy from sunmax .env if already configured)
# UPSTREAM_OPENAI_BASE_URL=https://your-llm-gw/v1
# OPENAI_API_KEY=sk-...
