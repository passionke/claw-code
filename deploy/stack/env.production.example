# Linux + Docker production — merge into repo root `.env`
#   cp deploy/stack/env.production.example .env
#   ./deploy/stack/gateway.sh up --release release-v1.4.5
# Do NOT cargo/build images on the server; CI pushes GHCR/ACR.
# Author: kejiqing

CLAW_DEPLOY_PROFILE=production

# Image namespace for --release (default ACR passionke; or CLAW_IMAGE_REGISTRY=ghcr)
# CLAW_IMAGE_PREFIX=ghcr.io/<org>

# --- LLM (not in this file — PostgreSQL → .claw/claw-llm-runtime.env) ---
# Admin → LLM in PG; gateway sync writes `.claw/claw-llm-runtime.env` + `.claw/claw-tap-upstream.json`.
# Repo root `.env` stays human-only (deploy profile, ports, etc.).

# --- project git (optional) ---
# Rules / CLAUDE / skills → PostgreSQL `project_config` (Admin), not env.
# Per-ds push repo → `git_sync_json` in PG (`PUT /v1/project/config/{dsId}`).
# Optional default commit author when gitSync omits authorName/authorEmail:
# CLAW_PROJECTS_GIT_AUTHOR=kejiqing <kejiqing@local>

# --- claude-tap (production: container) ---
# CLAUDE_TAP_IMAGE=ghcr.io/<org>/claude-tap:0.0.7

# --- optional external postgres ---
# CLAW_GATEWAY_DATABASE_URL=postgres://user:pass@host:5432/claw_gateway

# --- pool registry (optional — auto on `gateway.sh up`) ---
# CLAW_POOL_ID=pool-prod-1          # default: pool-<hostname> (stable per machine)
# CLAW_POOL_ADVERTISE_HOST=10.0.1.5 # default: LAN IP detect; used in claw_pool + live SSE join
