# Linux + Docker production ONLY — do NOT copy into macOS local .env
#   ./deploy/stack/gateway.sh install-docker          # first time: docker.io + compose + mirror
#   cp deploy/stack/env.production.example .env       # on the server only
#   ./deploy/stack/gateway.sh up --release release-v1.4.5
# Replace 192.168.9.252 with this machine's LAN IP. Author: kejiqing

CLAW_DEPLOY_PROFILE=production

# Image namespace for --release (default ACR passionke; or CLAW_IMAGE_REGISTRY=ghcr)
# CLAW_IMAGE_PREFIX=ghcr.io/<org>

# --- deploy (this host LAN IP) ---
CLAW_CLUSTER_ID=prod-claw-01
GATEWAY_HOST_PORT=18088
GATEWAY_PLAYGROUND_HOST_PORT=18675
# PLAYGROUND_PUBLIC_GATEWAY_BASE auto from CLAW_POOL_ADVERTISE_HOST on production up
CLAW_TIMEOUT_SECONDS=1800

# clawTap/LLM: Admin → PG; e2b worker env injected per-solve via e2b exec.
# Production: tap joins compose network — 8080 NOT published to public IP.
COMPOSE_PROJECT_NAME=claw
CLAUDE_TAP_MODE=docker
CLAUDE_TAP_IMAGE=crpi-cf9vxpq3n8or17mw.cn-hangzhou.personal.cr.aliyuncs.com/passionke/claw-tap:latest
CLAUDE_TAP_DOCKER_NETWORK=claw_default
# Publish tap proxy so Admin/worker/browser reach clawTap via CLAW_POOL_ADVERTISE_HOST (not container name).
CLAUDE_TAP_PUBLISH_PROXY=0.0.0.0:8080:8080
# Live viewer on localhost only (SSH tunnel); omit or set 0 to disable host publish.
CLAUDE_TAP_PUBLISH_LIVE=127.0.0.1:3000:3000
CLAW_DOCKER_NETWORK=claw_default
# Admin clawTap (after tap-up): host=claw-claude-tap proxyPort=8080 livePort=3000

# --- project git (optional) ---
# Rules / CLAUDE / skills → PostgreSQL `project_config` (Admin), not env.

# --- PostgreSQL ---
CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@postgres:5432/claw_gateway
CLAW_GATEWAY_PG_HOST_PORT=5433

# --- external postgres (gateway.sh up skips compose postgres when host is not postgres/127.0.0.1/localhost) ---
# CLAW_GATEWAY_DATABASE_URL=postgres://user:pass@192.168.9.252:5433/claw_gateway

# --- e2b / e2b (solve + interactive) ---
CLAW_INTERACTIVE_BACKEND=e2b
CLAW_SOLVE_ISOLATION=e2b
CLAW_E2B_API_URL=http://10.8.0.1:3000
CLAW_E2B_SANDBOX_URL=http://10.8.0.1:3002
# CLAW_E2B_API_KEY=
# CLAW_E2B_WORKER_STRICT_TEMPLATE=claw-worker-strict
# CLAW_E2B_WORKER_RELAXED_TEMPLATE=claw-worker-relaxed

# Per host: LAN IP for playground / external URLs
CLAW_POOL_ADVERTISE_HOST=192.168.9.252

# Do NOT set GATEWAY_IMAGE=:local on servers — use `gateway.sh up --release release-vX.Y.Z`.
