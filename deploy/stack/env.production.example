# Linux + Docker production — merge into repo root `.env`
#   cp deploy/stack/env.production.example .env
#   ./deploy/stack/gateway.sh up --release release-v1.4.5
# Do NOT cargo/build images on the server; CI pushes GHCR/ACR.
# Author: kejiqing

CLAW_DEPLOY_PROFILE=production

# Image namespace for --release (default ACR passionke; or CLAW_IMAGE_REGISTRY=ghcr)
# CLAW_IMAGE_PREFIX=ghcr.io/<org>

# --- deploy (this host LAN IP — use the same machine IP everywhere below) ---
CLAW_CLUSTER_ID=prod-claw-01
GATEWAY_HOST_PORT=18088
GATEWAY_PLAYGROUND_HOST_PORT=18675
PLAYGROUND_PUBLIC_GATEWAY_BASE=http://192.168.9.252:18088
CLAW_TIMEOUT_SECONDS=1800

# clawTap/LLM: Admin → PG
# Worker LLM env injected per-solve via pool Exec (-e), not worker env files.

# --- project git (optional) ---
# Rules / CLAUDE / skills → PostgreSQL `project_config` (Admin), not env.

# --- optional external postgres ---
# CLAW_GATEWAY_DATABASE_URL=postgres://user:pass@host:5432/claw_gateway

# --- pool (Linux production: host daemon, one path) ---
CLAW_POOL_HOST_DAEMON=1
CLAW_POOL_DAEMON_SKIP_BUILD=1
# CLAW_POOL_DAEMON_BIN=/home/admin/.local/bin/claw-pool-daemon
# CLAW_POOL_ID=pool-prod-1
# Pool: gateway container -> host pool daemon RPC; workers SSE publish (same LAN IP):
CLAW_POOL_ADVERTISE_HOST=192.168.9.252
CLAW_POOL_DAEMON_TCP_HOST=192.168.9.252
# Do NOT set GATEWAY_IMAGE=:local on servers — use `gateway.sh up --release release-vX.Y.Z`.
