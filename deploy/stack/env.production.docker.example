# Production servers (Docker Engine + compose v2). Merge into repo root `.env`.
#   cp deploy/stack/env.production.docker.example → edit → append/merge into .env
#   ./deploy/stack/gateway.sh up --release release-vX.Y.Z
# Author: kejiqing

CLAW_CONTAINER_RUNTIME=docker
CLAW_SOLVE_ISOLATION=docker_pool
# Do NOT set CLAW_CONTAINER_SOCKET on Docker hosts.

CLAW_IMAGE_REGISTRY=acr
CLAW_GATEWAY_PG_IMAGE=docker.io/library/postgres:17-alpine
GATEWAY_HOST_PORT=8088

CLAW_PROJECTS_GIT_URL=
CLAW_PROJECTS_GIT_BRANCH=main
CLAW_PROJECTS_GIT_AUTHOR=kejiqing <kejiqing@local>

OPENAI_API_KEY=
OPENAI_BASE_URL=
