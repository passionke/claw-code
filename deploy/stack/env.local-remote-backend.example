# 本地开发 · 远程后端（模式 B）— 连 dev-stable 稳定机，与 CI 隔离
#   cp deploy/stack/env.local-remote-backend.example .env
#   ./deploy/stack/gateway.sh pack-deploy local
#   ./deploy/stack/gateway.sh up
# Author: kejiqing
#
# 稳定机端口：PG 5434 / pool 9954 / tap 8081+3001（见 env.stable-dev-host.example）
# Admin clawTap：主机 10.22.28.94，代理 8081，Live 3001

CLAW_DEPLOY_PROFILE=local
CLAW_CLUSTER_ID=dev-stable

CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@10.22.28.94:5434/claw_gateway
CLAW_POOL_REMOTE_BASE=http://10.22.28.94:9954
CLAW_POOL_ID=pool-dev-stable

CLAW_LLM_PROXY=remote
CLAW_TAP_PROXY_URL=http://10.22.28.94:8081

# 可选：覆盖默认的 claw-workspace-remote（相对 deploy/stack 目录）
# CLAW_POOL_WORK_ROOT_BIND_SRC=claw-workspace-remote

PLAYGROUND_PUBLIC_GATEWAY_BASE=http://127.0.0.1:18088
GATEWAY_PLAYGROUND_HOST_PORT=18765
