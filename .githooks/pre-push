#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

if [[ ! -d "${repo_root}/rust" ]]; then
  echo "[pre-push] skip: rust workspace not found"
  exit 0
fi

# Read pushed refs from stdin (`<local-ref> <local-sha> <remote-ref> <remote-sha>` per line).
# If this push only updates tags, skip Rust checks entirely.
only_tags=1
while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
  [[ -z "${remote_ref}" ]] && continue
  if [[ "${remote_ref}" != refs/tags/* ]]; then
    only_tags=0
    break
  fi
done
if [[ "${only_tags}" -eq 1 ]]; then
  echo "[pre-push] skip: tag-only push"
  exit 0
fi

base_ref=""
if upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" 2>/dev/null)"; then
  base_ref="${upstream}"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
  base_ref="origin/main"
fi

if [[ -n "${base_ref}" ]]; then
  rust_changed=0
  while IFS= read -r path; do
    if [[ "${path}" == rust/* ]]; then
      rust_changed=1
      break
    fi
  done < <(git diff --name-only --diff-filter=ACMR "${base_ref}...HEAD")
  if [[ "${rust_changed}" -eq 0 ]]; then
    echo "[pre-push] skip: no rust/** changes in ${base_ref}...HEAD"
    exit 0
  fi
else
  echo "[pre-push] warn: no upstream/base ref found, running rust checks"
fi

echo "[pre-push] running cargo fmt --all --check"
(
  cd "${repo_root}/rust"
  cargo fmt --all --check
)

echo "[pre-push] rustfmt check passed"

echo "[pre-push] running cargo clippy --workspace --all-targets -- -D warnings"
(
  cd "${repo_root}/rust"
  cargo clippy --workspace --all-targets -- -D warnings
)

echo "[pre-push] clippy check passed"

echo "[pre-push] running cargo test --workspace"
(
  cd "${repo_root}/rust"
  cargo test --workspace
)

echo "[pre-push] all checks passed"
