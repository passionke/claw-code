deploy/stack/claw-workspace-local
deploy/stack/claw-workspace-ci-b
deploy/stack/claw-workspace-remote
deploy/stack/claw-workspace-host
deploy/stack/claw-logs-host
deploy/stack/.build.log
rust/target
sandbox/target
.git
