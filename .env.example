# Repo root: copy to `.env` and edit. Used by Podman gateway + scripts.
# Author: kejiqing
#
#   cp .env.example .env

# --- Container build (deploy/podman/build.sh loads this file) ---
# Hostname for library/rust + library/debian (no path). Matches GitHub Actions variable CONTAINER_BASE_REGISTRY.
CONTAINER_BASE_REGISTRY=docker.1ms.run

# --- Podman gateway (podman-compose substitution + container env_file) ---
GATEWAY_IMAGE=claw-gateway-rs:local
GATEWAY_HOST_PORT=8088
CLAW_TIMEOUT_SECONDS=120
INTERNAL_CLAUDE_TAP_HOST=http://host.containers.internal:8080
CLAW_HOST_LOG_DIR=./deploy/podman/claw-logs
CLAW_LOG_LEVEL=info
CLAW_TRACE_ENABLED=1

# Optional: override default model (else use root `.claw.json` "model" after code fix)
# CLAW_DEFAULT_MODEL=openai/qwen3-max

# --- Provider (often also in `.claw.json` "env"; process env wins if set) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- claude-tap (start-with-tap.sh) ---
UPSTREAM_OPENAI_BASE_URL=
CLAUDE_TAP_PORT=8080
CLAUDE_TAP_LIVE_PORT=3000

# --- Container pool (optional; gateway image includes podman CLI + mount host API socket) ---
# CLAW_SOLVE_ISOLATION=inprocess
# CLAW_SOLVE_ISOLATION=podman_pool
# Hard cap on worker count (local dev often 4). Omit for no extra cap.
# CLAW_POOL_SIZE_CAP=4
# CLAW_PODMAN_POOL_SIZE=4
# CLAW_PODMAN_POOL_MIN_IDLE=1
# CLAW_PODMAN_IMAGE=claw-gateway-worker:local
# Per-worker cgroup limits (podman run):
# CLAW_PODMAN_POOL_CPUS=1
# CLAW_PODMAN_POOL_MEMORY=1g
# CLAW_PODMAN_EXTRA_ARGS=
# Same network as claude-tap / MCP (compose default network name may vary; use `podman network ls`).
# CLAW_PODMAN_NETWORK=podman
# Rootless Linux: start `podman system service` or use default socket:
# PODMAN_HOST_SOCK=/run/user/1000/podman/podman.sock
# `up.sh` / `start-with-tap.sh` set CLAW_POOL_WORK_ROOT_HOST to deploy/podman/claw-workspace (do not override unless you know the host path).
