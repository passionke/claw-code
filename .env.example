# Repo root: copy to `.env` and edit. Author: kejiqing
#
# FC-only worker path (see docs/architecture-governance.md):
#   local      — macOS + podman + gateway.sh quick
#   production — Linux + docker + gateway.sh up --release release-vX.Y.Z
#
# Quick start:
#   cp deploy/stack/env.selfhosted-e2b.example .env   # recommended (external PG + e2b)
#   cp deploy/stack/env.local.example .env            # macOS all-local compose
#   cp deploy/stack/env.production.example .env       # Linux server
#
# Never create deploy/stack/.env (Compose overrides root .env).
# deploy/stack/*.env except .env.example are GENERATED — do not hand-edit.

CLAW_DEPLOY_PROFILE=local

# --- required ---
CLAW_CLUSTER_ID=local-dev
CLAW_INTERACTIVE_BACKEND=fc
CLAW_SOLVE_ISOLATION=fc

# e2b / FC (required for solve + interactive)
# CLAW_FC_API_URL=http://10.8.0.1:3000
# CLAW_FC_API_KEY=

# LLM + project agent config: PostgreSQL (Admin). Gateway sync writes OPENAI_* to runtime files.
# Optional dev bootstrap only:
# OPENAI_API_KEY=
# UPSTREAM_OPENAI_BASE_URL=

# Profile defaults (local): GATEWAY_IMAGE=claw-gateway-rs:local, GATEWAY_HOST_PORT=18088
# Profile defaults (production): images from `gateway.sh up --release`, GATEWAY_HOST_PORT=8088
#
# Full inventory: docs/env-config.md
# Documentation index: docs/README.md
