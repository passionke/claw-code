# Repo root: copy to `.env` and edit. Used by gateway deploy scripts.
# Author: kejiqing
#
# --- 唯一人手维护入口（部署相关）---
# 只编辑本仓库根目录的 `.env`（以及按需的 `.claw.json`）。`deploy/stack/` 下除本说明外的 `*.env`
# 均由脚本生成或由 compose 只读引用；不要手改中间物，避免和根 `.env` / `--release` 打架。
#
#   cp .env.example .env
#
# Do not create `deploy/stack/.env`: Compose auto-loads it and fights root `.env` / `--release` pins. Delete it if present.
#
# Upgrade GHCR tag without editing .env (writes deploy/stack/.claw-image-release.env as override):
#   ./deploy/stack/gateway.sh up --release release-v1.0.22
#   sudo ./deploy/stack/lib/install-pool-daemon-from-image.sh --release release-v1.0.22
# To drop the override and follow .env image lines again: rm deploy/stack/.claw-image-release.env
#
# --- 线上（推荐）：GitHub Actions `claw-code-image` 打 tag `release-*` 推 GHCR，服务器只 pull + up，不在服务器 cargo/build 镜像。---
# GATEWAY_IMAGE=ghcr.io/<github_owner>/claw-code:release-x.y.z
# CLAW_DOCKER_IMAGE=ghcr.io/<github_owner>/claw-gateway-worker:release-x.y.z
# CLAW_SOLVE_ISOLATION=docker_pool
# 线上标准：`./deploy/stack/gateway.sh up --release release-vX.Y.Z`（池 daemon 随 compose 起，无需宿主机装二进制）。
# 可选：`CLAW_POOL_DAEMON_TCP_HOST=claw-pool-daemon`（默认，compose 内服务名）；仅调试才改。

# 容器 CLI（build / compose / bench 共用一套逻辑）：默认 auto = PATH 里优先 podman，否则 docker。本地+线上同一 `.env` 可不写此项。
# 若本机同时装了 podman 与 docker 且必须指定：CLAW_CONTAINER_RUNTIME=podman 或 docker
# CLAW_CONTAINER_RUNTIME=auto
# 旧变量（仍兼容，等价于 docker）：# CLAW_USE_DOCKER=1

# --- Container build (deploy/stack/lib/build.sh loads this file) ---
# Hostname for library/rust + library/debian (no path). Matches GitHub Actions variable CONTAINER_BASE_REGISTRY.
CONTAINER_BASE_REGISTRY=docker.1ms.run
# rustup in podman image build: 1 = USTC mirror (needs working DNS); unset/0 = static.rust-lang.org.
# CLAW_USE_CN_RUST_MIRROR=1

# Gateway solve: before first LLM turn, inject SQLBot mcp_start + datasource list + table catalog into session jsonl (tool_use/tool_result).
# Unset = enabled. Set 0/false/off/no to disable (model calls MCP on its own; avoids fighting system prompt).
# CLAW_GATEWAY_SQLBOT_PREFLIGHT=0

# 镜像前缀（无 /claw-code 后缀）。`./deploy/stack/gateway.sh up --release release-v…` 会拼成 <prefix>/claw-code:<tag> 与 …/claw-gateway-worker:<tag>。
#
# 优先级：`CLAW_IMAGE_PREFIX` / `CLAW_GHCR_PREFIX`（旧名）> 从 `GATEWAY_IMAGE` 解析 …/claw-code > 按 `CLAW_IMAGE_REGISTRY` 选默认前缀。
# 默认：`CLAW_IMAGE_REGISTRY` 未设或为 acr → 阿里云个人版 ACR `passionke`（与 Actions claw-code-acr 推送路径一致）。
# 改用 GHCR（不设前缀时）：`CLAW_IMAGE_REGISTRY=ghcr`（默认 `ghcr.io/passionke`，可用 `CLAW_GHCR_DEFAULT_PREFIX` 覆盖）。
# 自定义 ACR 命名空间/host：`CLAW_ACR_IMAGE_PREFIX=crpi-….personal.cr.aliyuncs.com/<namespace>`
#
# 显式写死前缀（最高优先级，示例）：
# CLAW_IMAGE_PREFIX=crpi-cf9vxpq3n8or17mw.cn-hangzhou.personal.cr.aliyuncs.com/passionke
# CLAW_IMAGE_PREFIX=ghcr.io/passionke
# CLAW_IMAGE_REGISTRY=ghcr
# 旧变量名（等价于 CLAW_IMAGE_PREFIX）：# CLAW_GHCR_PREFIX=ghcr.io/passionke

# --- Podman gateway (podman-compose substitution + container env_file) ---
GATEWAY_IMAGE=claw-gateway-rs:local
GATEWAY_HOST_PORT=8088
CLAW_TIMEOUT_SECONDS=120
INTERNAL_CLAUDE_TAP_HOST=http://host.containers.internal:8080
CLAW_HOST_LOG_DIR=./deploy/stack/claw-logs
# Gateway session / turn / feedback (PostgreSQL). Required for http-gateway-rs (local or compose).
# deploy/stack/podman-compose.yml starts `postgres` and defaults to:
#   postgres://claw_gateway:clawGw9Dev_Pg@postgres:5432/claw_gateway  (gateway container → postgres service)
# Host-run gateway against compose PG (host maps CLAW_GATEWAY_PG_HOST_PORT, default 5433):
# CLAW_GATEWAY_DATABASE_URL=postgres://claw_gateway:clawGw9Dev_Pg@127.0.0.1:5433/claw_gateway
# Optional compose-only PG image/credentials (see deploy/stack/podman-compose.yml):
# CLAW_GATEWAY_PG_IMAGE=docker.1ms.run/library/postgres:17-alpine
# CLAW_GATEWAY_PG_USER=claw_gateway
# CLAW_GATEWAY_PG_PASSWORD=clawGw9Dev_Pg
# CLAW_GATEWAY_PG_DATABASE=claw_gateway
# CLAW_GATEWAY_PG_HOST_PORT=5433
CLAW_LOG_LEVEL=info
CLAW_TRACE_ENABLED=1

# --- Gateway tool allow-list (`/v1/solve`, `/v1/solve_async`) ---
# Unset or empty → all built-in tools allowed (bash, read_file, Skill, MCP, …).
# ds_1 Boss 本地推荐：`bash,mcp__sqlbot-streamable__*,report_progress`（见 deploy/stack/claw-workspace/ds_1/TUNING-LOG.md）
# CLAW_ALLOWED_TOOLS=bash,mcp__sqlbot-streamable__*,report_progress

# Default solve path: Podman worker pool (unset CLAW_SOLVE_ISOLATION or leave podman_pool). `docker_pool` for Docker workers.
CLAW_SOLVE_ISOLATION=podman_pool

# Compose 服务 `claw-pool-daemon`（`gateway.sh up` 自动起）在宿主机上 `podman`/`docker run` worker；网关经 TCP 连它（`CLAW_POOL_DAEMON_TCP_*`）。
# Port for host `claw-pool-daemon` TCP bind (`0.0.0.0:$PORT`); gateway gets `CLAW_POOL_DAEMON_TCP=<host>:$PORT` from generated `gateway.env`.
CLAW_POOL_DAEMON_PORT=9943
# Hostname the *gateway container* uses to dial the daemon (must match where `docker`/`podman` run workers).
# Local Podman: default host.containers.internal. Docker Desktop: often host.docker.internal (set explicitly if you use compose-include defaults).
# Same compose stack as a `claw-pool-daemon` service: e.g. CLAW_POOL_DAEMON_TCP_HOST=claw-pool-daemon
# CLAW_POOL_DAEMON_TCP_HOST=host.containers.internal

# Pool sizing (local default: max 4 workers, keep 1 warm)
CLAW_POOL_SIZE_CAP=4
CLAW_PODMAN_POOL_SIZE=4
CLAW_PODMAN_POOL_MIN_IDLE=1
CLAW_PODMAN_IMAGE=claw-gateway-worker:local

# Optional per-worker limits (podman run --cpus / --memory)
# CLAW_PODMAN_POOL_CPUS=1
# CLAW_PODMAN_POOL_MEMORY=1g
# Extra args appended to every `podman run` for claw-worker-* pool workers (whitespace-separated).
# Same-turn parallel fan-out for SQLBot `mcp_question_then_analysis` (multiple tool_use in one turn).
# Set to 0 / false / off to disable (serial MCP only; no `[parallel-friendly]` tool-description suffix).
# CLAW_MCP_PARALLEL_FANOUT=0
# Example: long HTTP MCP (e.g. sqlbot-streamable) needs a larger tool-call budget inside the worker.
# CLAW_PODMAN_EXTRA_ARGS=-e CLAW_MCP_TOOL_CALL_TIMEOUT_MS=180000
# If your shell or compose mangles spaces, quote: CLAW_PODMAN_EXTRA_ARGS="-e CLAW_MCP_TOOL_CALL_TIMEOUT_MS=180000"
# Do not duplicate these in deploy/stack/podman-compose.yml `environment:` with "${VAR:-}" — that
# overrides this file (compose interpolation does not read repo-root .env). Author: kejiqing
# Pool: `CLAW_WORKER_ENV_FILE` points at this file; workers mount it and `gateway-solve-once` loads keys declared in
# `rust/crates/gateway-solve-turn/src/worker_env.rs` (no deploy-side ALLOW list / worker-openai.env snapshot).
# `pool-daemon-up.sh` sets `CLAW_WORKER_ENV_FILE=<repo>/.env` on the host daemon automatically.
# progressHistory 单条 message 最大字符数（默认 80，超出截断并加 ...）；改后 `gateway.sh up` 重建 worker 即可。
# CLAW_PROGRESS_MESSAGE_MAX_CHARS=120
# CLAW_PODMAN_NETWORK=podman

# Optional: override default model (else use root `.claw.json` "model" after code fix)
# CLAW_DEFAULT_MODEL=openai/qwen3-max

# --- Provider (often also in `.claw.json` "env"; process env wins if set) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- claude-tap (start-with-tap.sh; Author: kejiqing) ---
# CLAUDE_TAP_MODE: docker | source | native
#   docker — build/run image from fork (recommended when you customize claude-tap)
#   source — run ${CLAUDE_TAP_BUILD_CONTEXT}/.venv/bin/claude-tap (uv sync in fork)
#   native — PyPI/uv tool `claude-tap` on PATH
# Production servers without ../claude-tap fork: use native (pip/uv install claude-tap).
# CLAUDE_TAP_MODE=native
# CLAUDE_TAP_MODE=docker
# CLAUDE_TAP_BUILD_CONTEXT=/path/to/claude-tap
# CLAUDE_TAP_IMAGE=claude-tap:local
# Remote: ghcr.io/passionke/claude-tap:release-v0.0.3  (or ./gateway.sh tap-restart --release release-v0.0.3)
# CLAUDE_TAP_REBUILD=1
# CLAUDE_TAP_PLATFORM=linux/arm64
UPSTREAM_OPENAI_BASE_URL=
CLAUDE_TAP_PORT=8080
CLAUDE_TAP_LIVE_PORT=3000

# Optional override for pool bind roots. In the default compose stack, deploy/stack/.claw-pool-workspace.env
# sets this to /var/lib/claw/workspace (path inside the gateway container). Do NOT set a macOS /Users/... path
# here when the gateway runs in a Linux container — it will not exist in that filesystem and startup fails.
# CLAW_POOL_WORK_ROOT_HOST=/var/lib/claw/workspace

# --- 线上 Docker 池（与本地共用脚本；auto 会在无 podman 时选 docker。若要强制 docker：CLAW_CONTAINER_RUNTIME=docker）---
# CLAW_SOLVE_ISOLATION=docker_pool
# CLAW_POOL_DAEMON_TCP_HOST=host.docker.internal
# CLAW_DOCKER_IMAGE=ghcr.io/<org>/claw-gateway-worker:release-x.y.z
# CLAW_DOCKER_POOL_SIZE=4
# CLAW_DOCKER_POOL_MIN_IDLE=1
# CLAW_DOCKER_POOL_CPUS=1
# CLAW_DOCKER_POOL_MEMORY=1g
# Optional: CLAW_DOCKER_NETWORK=<compose_default>  DOCKER_HOST=…
# Same as CLAW_PODMAN_EXTRA_ARGS but for `docker run` workers (docker_pool).
# CLAW_DOCKER_EXTRA_ARGS=-e CLAW_MCP_TOOL_CALL_TIMEOUT_MS=180000
# `./deploy/stack/gateway.sh up` starts host `claw-pool-daemon`; workers are `claw-worker-*` on the host runtime (podman/docker); legacy `claw-gw-*` names are removed on up/daemon restart.
#
# 备选：不设 CLAW_POOL_DAEMON_*，网关进程内嵌 PoolManager + 挂载 `docker.sock`（镜像需 docker CLI；当前网关镜像默认只带 podman）。

# --- Projects Git（必填；网关启动时检查，缺失或空串直接退出）---
# ds_<id>/home 镜像仓库：init 拉取，claude/skills 写后 push。不要写进业务代码，只走环境变量。
# HTTPS + PAT（无凭据 URL 时必须设置 CLAW_PROJECTS_GIT_TOKEN，否则启动失败）。
# 内网 `http://` 且无 URL 内嵌用户名时，同样会把 token 注入为 `http://x-access-token:<token>@host/...`（GitLab 若不接受该用户名，请改用 URL 内嵌 `oauth2:<token>@` 等并留空 token）。
CLAW_PROJECTS_GIT_URL=https://github.com/passionke/claw-code-projects.git
CLAW_PROJECTS_GIT_BRANCH=main
CLAW_PROJECTS_GIT_AUTHOR=kejiqing <kejiqing@local>
CLAW_PROJECTS_GIT_TOKEN=
# 若用 SSH：改为 git@github.com:... 且可留空 CLAW_PROJECTS_GIT_TOKEN
# 多机时：可选，对镜像 `git pull` 后尝试刷新各 `ds_*/home`（仅当该 ds 的锁空闲，避免与写接口抢锁）。0 或不设 = 关闭。
# CLAW_PROJECTS_GIT_DS_HOME_POLL_INTERVAL_SECS=120
