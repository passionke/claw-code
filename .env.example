# Repo root: copy to `.env` and edit. Author: kejiqing
#
# Two profiles only (see docs/env-config.md):
#   local      — macOS + podman + pack-deploy local
#   production — Linux + docker + gateway.sh up --release release-vX.Y.Z
#
# Quick start:
#   cp deploy/stack/env.local.example .env          # macOS dev
#   cp deploy/stack/env.production.example .env     # Linux server
#
# Never create deploy/stack/.env (Compose overrides root .env).
# deploy/stack/*.env except .env.example are GENERATED — do not hand-edit.

CLAW_DEPLOY_PROFILE=local

# --- required ---
CLAW_CLUSTER_ID=local-dev

# LLM + project agent config: PostgreSQL (Admin). Gateway sync writes OPENAI_* to this file at runtime.
# Optional dev bootstrap only:
# OPENAI_API_KEY=
# UPSTREAM_OPENAI_BASE_URL=
# Project agent config: PostgreSQL project_config (Admin), not env.
# Optional default git author for per-ds gitSync push:
# CLAW_PROJECTS_GIT_AUTHOR=kejiqing <kejiqing@local>

# Profile defaults (local): podman_pool, GATEWAY_IMAGE=claw-gateway-rs:local, GATEWAY_HOST_PORT=18088
# Profile defaults (production): docker_pool, images from `gateway.sh up --release`, GATEWAY_HOST_PORT=8088
#
# Full inventory: docs/env-config.md
# Generated paths: docs/env-files.md
