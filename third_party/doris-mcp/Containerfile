FROM node:20-bookworm-slim AS build

ARG NPM_REGISTRY=https://registry.npmmirror.com
WORKDIR /app

COPY package*.json ./
RUN npm config set registry "${NPM_REGISTRY}" && npm ci

COPY tsconfig.json ./
COPY src ./src
COPY scripts ./scripts
RUN npm run build

FROM node:20-bookworm-slim AS runtime

ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PYTHONUNBUFFERED=1 \
    DORIS_CONFIG=/app/config/doris_clusters.yaml \
    CLAW_SERVICE_MODE=mcp \
    CLAW_HTTP_PORT=18080 \
    CLAW_BIN=claw

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip ca-certificates \
    && python3 -m pip install --break-system-packages --no-cache-dir -i "${PIP_INDEX_URL}" \
      sqlglot fastapi uvicorn pydantic PyYAML \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist
COPY scripts ./scripts
COPY config ./config
COPY http_gateway ./http_gateway
RUN chmod +x /app/scripts/entrypoint.sh
EXPOSE 18080

ENTRYPOINT ["/app/scripts/entrypoint.sh"]
