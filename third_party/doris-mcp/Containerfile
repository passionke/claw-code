ARG NODE_BASE_IMAGE=docker.1ms.run/library/node:20-bookworm-slim
ARG RUST_BASE_IMAGE=docker.1ms.run/library/rust:1.88-bookworm

FROM ${NODE_BASE_IMAGE} AS build

ARG NPM_REGISTRY=https://registry.npmmirror.com
WORKDIR /app

COPY third_party/doris-mcp/package*.json ./
RUN npm config set registry "${NPM_REGISTRY}" && npm ci

COPY third_party/doris-mcp/tsconfig.json ./
COPY third_party/doris-mcp/src ./src
COPY third_party/doris-mcp/scripts ./scripts
RUN npm run build

FROM ${RUST_BASE_IMAGE} AS claw_build

WORKDIR /src
RUN apt-get update \
    && apt-get install -y --no-install-recommends pkg-config libssl-dev ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY rust ./rust
RUN cd /src/rust && cargo build -p rusty-claude-cli --release

FROM ${NODE_BASE_IMAGE} AS runtime

ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PYTHONUNBUFFERED=1 \
    DORIS_CONFIG=/app/config/doris_clusters.yaml \
    CLAW_SERVICE_MODE=mcp \
    CLAW_HTTP_PORT=18080 \
    CLAW_BIN=/usr/local/bin/claw

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip ca-certificates \
    && python3 -m pip install --break-system-packages --no-cache-dir -i "${PIP_INDEX_URL}" \
      sqlglot fastapi uvicorn pydantic PyYAML \
    && rm -rf /var/lib/apt/lists/*

COPY third_party/doris-mcp/package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/dist ./dist
COPY --from=claw_build /src/rust/target/release/claw /usr/local/bin/claw
COPY third_party/doris-mcp/scripts ./scripts
COPY third_party/doris-mcp/config ./config
COPY third_party/doris-mcp/http_gateway ./http_gateway
RUN chmod +x /app/scripts/entrypoint.sh
EXPOSE 18080

ENTRYPOINT ["/app/scripts/entrypoint.sh"]
